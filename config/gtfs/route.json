    "default_route_long_name_enabled": true,
    "route_long_name_cleaners": [
        {
            "regex": "(\\* )",
            "ignore_case": true
        }
    ],
    "route_colors_ignored": [
        "7476D9",
        "0000FF"
    ],
    "direction_finder_enabled": true,
    "trip_headsign_remove_via": true,
    "trip_headsign_cleaners": [
        {
            "regex": "(^)(\\d+)(\\w?)(\\s)",
            "ignore_case": true
        },
        {
            "regex": "([\\s]+only[\\s]*$)",
            "ignore_case": true
        },
        {
            "regex": "metrolink",
            "ignore_case": true,
            "is_word": true
        },
        {
            "regex": "express",
            "ignore_case": true,
            "is_word": true,
            "replacement": " "
        }
    ],
    "stop_id_clean_merged": true,
    "use_stop_id_for_stop_code": true,
    "stop_name_cleaners": [
        {
            "regex": "(\\[[^]]*])",
            "ignore_case": true
        },
        {
            "regex": "(([^<]+)(<)([^>]+)(>))",
            "ignore_case": true,
            "replacement": "$2$4"
        },
        {
            "regex": "((\\s)*(after and opposite|afteropposite|after|before and opposite|beforeopposite|before|in front of|opposite and after|opposite and before|oppositeafter|oppositebefore|opposite)(\\s)*)",
            "ignore_case": true,
            "replacement": " / "
        },
        {
            "regex": "([ ]*\\([\\d]+\\)$)",
            "ignore_case": true
        }
    ]
}